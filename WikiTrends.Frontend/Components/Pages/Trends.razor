@page "/trends"
@using WikiTrends.Contracts.Api
@using WikiTrends.Contracts.Events
@inject WikiTrends.Frontend.Services.GatewayApiClient Api

<PageTitle>Trends</PageTitle>

<h1>Trends</h1>

<div class="row g-3 align-items-end">
    <div class="col-md-3">
        <label class="form-label">Period</label>
        <select class="form-select" @bind="_period">
            @foreach (var p in Enum.GetValues<TrendPeriod>())
            {
                <option value="@p">@p</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label">Limit</label>
        <input class="form-control" type="number" @bind="_limit" min="1" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Min anomaly score</label>
        <input class="form-control" type="number" step="0.01" @bind="_minScore" />
    </div>

    <div class="col-md-2">
        <button class="btn btn-primary" @onclick="LoadAsync" disabled="@_loading">Load</button>
    </div>
</div>

@if (_loading)
{
    <p class="mt-3">Loading...</p>
}
else if (_error is not null)
{
    <p class="text-danger mt-3">@_error</p>
}
else if (_data is null)
{
    <p class="mt-3">No data</p>
}
else
{
    <p class="mt-3">Generated: @_data.GeneratedAt</p>

    <table class="table table-sm table-striped">
        <thead>
        <tr>
            <th>TopicId</th>
            <th>Name</th>
            <th>EditCount</th>
            <th>AnomalyScore</th>
            <th>Change%</th>
            <th>Direction</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var t in _data.Topics)
        {
            <tr>
                <td>
                    <a href="@($"/topics/{t.TopicId}?period={_period}")">@t.TopicId</a>
                </td>
                <td>@t.Name</td>
                <td>@t.EditCount</td>
                <td>@t.AnomalyScore</td>
                <td>@t.ChangePercent</td>
                <td>@t.Direction</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private TrendsResponse? _data;
    private string? _error;
    private bool _loading;

    private TrendPeriod _period = TrendPeriod.Last24Hours;
    private int _limit = 20;
    private float _minScore;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _data = await Api.GetTrendsAsync(new GetTrendsRequest
            {
                Period = _period,
                Limit = _limit,
                MinAnomalyScore = _minScore
            });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
