{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Service} | {Message:lj}{NewLine}{Exception}"
        }
      },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "wiki-classifier-v2-group",
    "AutoOffsetReset": "earliest",
    "EnableAutoCommit": false,
    "AutoCommitIntervalMs": 5000,
    "SessionTimeoutMs": 30000,
    "MaxPollIntervalMs": 300000,
    "MetricsEnabled": true,
    "MetricsLogIntervalSeconds": 10,
    "SlowMessageThresholdMs": 2000
  },
  "Topics": {
    "RawEdits": "wiki.raw-edits",
    "EnrichedEdits": "wiki.enriched.v2",
    "ClassifiedEdits": "wiki.classified",
    "TrendUpdates": "wiki.trend-updates",
    "RecalculateBaselineCommands": "wiki.commands.recalculate-baseline",
    "InvalidateCacheCommands": "wiki.commands.invalidate-cache"
  },
  "ServiceUrls": {
    "AggregatorBaseUrl": "http://localhost:5080",
    "AnalyticsBaseUrl": "http://localhost:5081",
    "ClassifierBaseUrl": "http://localhost:5082",
    "EnricherBaseUrl": "http://localhost:5083"
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=wikitrends;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Database": {
    "MigrateOnStartup": false
  },
  "Classifier": {
    "WikidataCacheHours": 24,
    "WorkerCount": 6,
    "SparqlTimeoutSeconds": 8,
    "SparqlCircuitOpenSeconds": 300,
    "SparqlCacheHours": 48
  }
}
