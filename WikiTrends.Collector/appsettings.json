{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Service} {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/collector-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Service} {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "wiki-collector-group",
    "AutoOffsetReset": "earliest",
    "EnableAutoCommit": false,
    "AutoCommitIntervalMs": 5000,
    "SessionTimeoutMs": 30000,
    "MaxPollIntervalMs": 300000,
    "Producer": {
      "Acks": "all",
      "EnableIdempotence": true,
      "MaxInFlight": 5,
      "LingerMs": 5,
      "BatchSize": 16384
    }
  },
  "Topics": {
    "RawEdits": "wiki.raw-edits",
    "EnrichedEdits": "wiki.enriched",
    "ClassifiedEdits": "wiki.classified",
    "TrendUpdates": "wiki.trend-updates",
    "RecalculateBaselineCommands": "wiki.commands.recalculate-baseline",
    "InvalidateCacheCommands": "wiki.commands.invalidate-cache"
  },
  "ServiceUrls": {
    "AggregatorBaseUrl": "http://localhost:5080",
    "AnalyticsBaseUrl": "http://localhost:5081",
    "ClassifierBaseUrl": "http://localhost:5082",
    "EnricherBaseUrl": "http://localhost:5083"
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=wikitrends;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Database": {
    "MigrateOnStartup": false
  },
  "WikiStream": {
    "StreamUrl": "https://stream.wikimedia.org/v2/stream/recentchange",
    "AllowedWikis": [ "enwiki", "ruwiki" ],
    "AllowedNamespaces": [ 0 ],
    "AllowedTypes": [ "edit" ],
    "ReconnectDelaySeconds": 5,
    "MaxReconnectDelaySeconds": 60,
    "HealthCheckIntervalSeconds": 30
  },
  "Analytics": {
    "TrendCalculationIntervalSeconds": 60,
    "TopTopicsLimit": 50,
    "TopArticlesPerTopicLimit": 20
  },
  "ClickHouse": {
    "BaseUrl": "http://localhost:8123",
    "Database": "wikitrends",
    "User": null,
    "Password": null
  }
}